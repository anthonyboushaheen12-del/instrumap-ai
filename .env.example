# Anthropic API Key (server-side only, used by api/analyze.js on Vercel)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase (client-side, used for project management)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Development — set to true to use mock data instead of calling Claude
VITE_USE_MOCK=false
