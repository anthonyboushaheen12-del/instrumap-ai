# API Keys for P&ID Analysis
# You need ONE of these APIs

# OpenRouter API Key (RECOMMENDED - supports PDFs)
# Get your API key from: https://openrouter.ai/keys
# Free tier available, supports Claude which can read PDFs
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini API Key (images only - NO PDF support)
# Get your API key from: https://aistudio.google.com/apikey
# VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key (supports PDFs but requires paid plan)
# Get your API key from: https://console.anthropic.com/
# VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Note: Without any API key, the app will use mock data for development
